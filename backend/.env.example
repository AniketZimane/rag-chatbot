# ── LLM & Embeddings ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model choices (cost vs quality tradeoff)
# Embeddings: text-embedding-3-small ($0.02/1M tokens) vs text-embedding-3-large ($0.13/1M)
EMBED_MODEL=text-embedding-3-small

# LLM: gpt-4o-mini (fast, cheap) vs gpt-4o (best quality)
LLM_MODEL=gpt-4o-mini

# ── Vector DB ─────────────────────────────────────────────────
# ChromaDB local persist path (no infra cost for dev/demo)
CHROMA_PERSIST_DIR=./chroma_db

# ── RAG Tuning ────────────────────────────────────────────────
# Number of chunks to retrieve per query
TOP_K=6
